# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored; never commit real secrets.

# Postgres password for the vault database
POSTGRES_PASSWORD=

# HMAC secret used by the vault service to verify tenant auth tokens.
# Generate with: openssl rand -hex 32
VAULT_AUTH_SECRET=

# AES-256-GCM encryption key for secrets stored in the vault database.
# Generate with: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=

# HMAC secret used by the API gateway to verify inbound JWTs.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated list of allowed CORS origins for the API gateway.
ALLOWED_ORIGINS=http://localhost:8080

# Token the CLI sends to the detection service (Bearer token).
# Must match what the detection service expects.
SENTINEL_CLI_TOKEN=

# Optional: SQS queue URL for the rotation worker.
SQS_ROTATION_QUEUE_URL=

# Optional: AWS credentials for rotation worker (SQS + IAM).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Detection service tuning
# Minimum confidence threshold for findings (0.0–1.0, default 0.5)
SENTINEL_MIN_CONFIDENCE=0.5
# Comma-separated rule IDs to disable, e.g. "high_entropy,bearer_token"
SENTINEL_DISABLED_RULES=
# Set to "1" to enable live secret validation endpoints
SENTINEL_ENABLE_VALIDATION=
